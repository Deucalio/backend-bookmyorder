# Copy to `.env` and fill in real values.

# HTTP port the Express server binds to.
PORT=3000

# PostgreSQL connection string (same database as book-my-order Remix app).
DATABASE_URL=postgresql://user:password@localhost:5432/bookmyorder

# Shared secret used by the Remix app to authenticate background sync requests.
# Set the same value in both this file and book-my-order/.env as BACKEND_INTERNAL_SECRET.
INTERNAL_SECRET=change-me-to-a-random-secret

# Shopify Admin API version used for direct GraphQL calls. Defaults to 2025-10.
# SHOPIFY_API_VERSION=2025-10

# Leopards Courier (LCS) base URL.
# Default: https://merchantapi.leopardscourier.com
# LCS_API_URL=https://merchantapistaging.leopardscourier.com

# TCS base URL.
# Default: https://ociconnect.tcscourier.com/ecom
# TCS_API_URL=https://ociconnect.tcscourier.com/ecom

# Optional fallback long-lived Bearer token used when callers do not supply
# `bearertoken` inline. Leave empty if every request carries its own.
# TCS_BEARER_TOKEN=
