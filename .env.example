# Copy to `.env` and fill in real values. All variables are optional —
# the courier kit ships with sensible defaults.

# HTTP port the Express server binds to.
PORT=3000

# Leopards Courier (LCS) base URL.
# Default: https://merchantapi.leopardscourier.com
# LCS_API_URL=https://merchantapistaging.leopardscourier.com

# TCS base URL.
# Default: https://ociconnect.tcscourier.com/ecom
# TCS_API_URL=https://ociconnect.tcscourier.com/ecom

# Optional fallback long-lived Bearer token used when callers do not supply
# `bearertoken` inline. Leave empty if every request carries its own.
# TCS_BEARER_TOKEN=
