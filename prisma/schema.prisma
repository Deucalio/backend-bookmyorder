datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// SHOPIFY SESSION (do not modify)
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  // Required by expiringOfflineAccessTokens future flag in shopify.server.ts
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// SHOP
model Shop {
  id            String    @id @default(cuid())
  shopDomain    String    @unique
  shopName      String?
  email         String?
  logoUrl       String?
  isActive      Boolean   @default(true)
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?

  plan             String    @default("free")
  // Merchant has explicitly picked a plan in the onboarding flow. The default
  // `plan` is "free" so we wouldn't otherwise know — this flag is the gate.
  isOnboarded      Boolean   @default(false)
  credits          Int       @default(300)
  creditsRenewedAt DateTime?

  initialSyncCompletedAt DateTime?
  lastOrderSyncAt        DateTime?
  ordersBackfilledCount  Int       @default(0)
  lastSyncError          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders           Order[]
  shopCouriers     ShopCourier[]
  courierStats     CourierCityStats[]
  webhookEvents    WebhookEvent[]
  addressMatchLogs AddressMatchLog[]
  customTabs       CustomTab[]
  stoppedOrders    StoppedOrder[]

  @@index([shopDomain])
}

// ORDER
model Order {
  id     String @id @default(cuid())
  shopId String

  shopifyOrderId  BigInt
  shopifyOrderGid String?
  orderName       String

  customerName  String
  customerEmail String?
  customerPhone String?

  provinceId String?
  cityId     String?
  areaId     String?

  addressMatchLogId String?

  rawProvince  String?
  rawCity      String?
  rawArea      String?
  addressLine1 String?
  addressLine2 String?
  postalCode   String?

  subtotal    Float
  totalAmount Float
  codAmount   Float  @default(0)
  currency    String @default("PKR")
  // Merchant-set parcel weight (kg) saved from the orders editor. Used as the
  // booking weight; null falls back to the editor's default.
  parcelWeight Float?

  financialStatus   String
  fulfillmentStatus String
  // Open | Closed | Cancelled — derived from Shopify cancelledAt / closedAt.
  orderStatus       String   @default("Open")
  cancelledAt       DateTime?
  closedAt          DateTime?
  tags              String?

  lineItems Json

  shopifyFulfillmentOrderId       BigInt?
  shopifyFulfillmentOrderStatus   String?
  shopifyFulfillmentOrderUpdatedAt DateTime?

  shopifyCreatedAt DateTime
  shopifyUpdatedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  province         Province?        @relation(fields: [provinceId], references: [id])
  city             City?            @relation(fields: [cityId], references: [id])
  area             Area?            @relation(fields: [areaId], references: [id])
  addressMatchLog  AddressMatchLog? @relation(fields: [addressMatchLogId], references: [id], onDelete: SetNull)
  fulfillments     Fulfillment[]

  @@unique([shopId, shopifyOrderId])
  @@index([shopId, fulfillmentStatus])
  @@index([shopId, cityId])
  @@index([shopId, shopifyCreatedAt])
}

// FULFILLMENT
model Fulfillment {
  id      String @id @default(cuid())
  orderId String

  shopifyFulfillmentId  String?
  shopifyFulfillmentGid String?

  courierCode String
  courierName String

  trackingNumber String?
  trackingUrl    String?
  slipLink       String?

  status             String    @default("pending")
  lastTrackingStatus String?
  lastTrackingAt     DateTime?
  deliveryOutcome    String    @default("pending")

  bookedAt             DateTime?
  fulfilledOnShopifyAt DateTime?
  bookingResponse      Json?
  bookingError         String?

  items    Json
  slipData Json?

  weightKg       Float?
  numberOfPieces Int     @default(1)
  specialNotes   String?

  // "app" = booked by BookMyOrder courier flow; "shopify" = synced/imported from Shopify
  source String @default("shopify")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingEvents    TrackingEvent[]
  bookingAttempts   BookingAttempt[]
  trackingRetryRow  TrackingRetryQueue?

  @@index([orderId])
  @@index([trackingNumber])
  @@index([courierCode, deliveryOutcome])
  @@index([status])
}

// TRACKING EVENTS
// Each row is one upstream tracking event from the trackmyorder.pk API. The
// API returns events with a normalized `status` field (DELIVERED, IN_TRANSIT,
// etc.), so we no longer keep a separate rawStatus column. UNKNOWN events are
// filtered out at ingest — they're duplicate-with-timezone-skew noise.
model TrackingEvent {
  id            String @id @default(cuid())
  fulfillmentId String

  normalizedStatus String

  description String?
  location    String?
  receiver    String?
  reason      String?

  eventAt   DateTime
  fetchedAt DateTime @default(now())

  rawData Json?

  fulfillment Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)

  // Dedupe key: description differentiates events at the same minute with the
  // same status (e.g. "Arrived at Station in LAHORE" vs "Waiting for Delivery").
  @@unique([fulfillmentId, eventAt, description])
  @@index([fulfillmentId, eventAt])
}

// TRACKING RETRY QUEUE
// Populated only when a batch HTTP call to the tracking provider fails after
// 4 in-run retries. Next cron run drains this table first. After 5 cron runs
// of continued failure the row is flagged permanentlyFailed and skipped until
// manually cleared.
model TrackingRetryQueue {
  id            String   @id @default(cuid())
  fulfillmentId String   @unique
  attemptCount  Int      @default(0)
  lastError     String?
  lastAttemptAt DateTime?
  permanentlyFailed Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  fulfillment Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)

  @@index([permanentlyFailed])
}

// SHOP COURIER (per-merchant credentials)
model ShopCourier {
  id          String  @id @default(cuid())
  shopId      String
  courierCode String
  courierName String
  isEnabled   Boolean @default(false)
  isDefault   Boolean @default(false)

  credentials Json @default("{}")
  meta_data   Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, courierCode])
  @@index([shopId])
}

// DELIVERY RATIO STATS
model CourierCityStats {
  id          String @id @default(cuid())
  shopId      String
  courierCode String
  cityId      String

  totalBooked    Int   @default(0)
  totalDelivered Int   @default(0)
  totalReturned  Int   @default(0)
  totalFailed    Int   @default(0)
  deliveryRatio  Float @default(0)

  lastCalculatedAt DateTime @updatedAt
  createdAt        DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  city City @relation(fields: [cityId], references: [id])

  @@unique([shopId, courierCode, cityId])
  @@index([shopId, cityId])
}

// LOCATIONS (Province > City > Area)
model Province {
  id     String  @id
  name   String  @unique
  cities City[]
  orders Order[]
}

model City {
  id         String   @id
  provinceId String
  name       String
  aliases    String[] @default([])
  courierMappings Json?    // { tcs: {...}, leopards: {...}, daewoo: {...} }


  province         Province           @relation(fields: [provinceId], references: [id])
  areas            Area[]
  orders           Order[]
  courierCityStats CourierCityStats[]
  matchedInLogs    AddressMatchLog[]  @relation("MatchedCity")
  chosenInLogs     AddressMatchLog[]  @relation("ChosenCity")
  bookingAttempts  BookingAttempt[]   @relation("BookingAttemptCity")

  @@index([provinceId])
  @@index([name])
}

model Area {
  id      String   @id
  cityId  String
  name    String
  zone    String?
  aliases String[] @default([])

  city          City              @relation(fields: [cityId], references: [id])
  orders        Order[]
  matchedInLogs AddressMatchLog[] @relation("MatchedArea")
  chosenInLogs  AddressMatchLog[] @relation("ChosenArea")

  @@index([cityId])
  @@index([name])
}

// WEBHOOK IDEMPOTENCY
model WebhookEvent {
  id          String    @id @default(cuid())
  shopId      String
  topic       String
  shopifyId   String
  payload     Json
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  attempts    Int       @default(0)
  receivedAt  DateTime  @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, shopifyId, topic])
  @@index([shopId, processed])
}

// BOOKING ATTEMPT AUDIT LOG
model BookingAttempt {
  id              String   @id @default(cuid())
  fulfillmentId   String?
  orderId         String
  // Internal city id booked to (FK). Lets us aggregate bookings per city.
  cityId          String?
  courierCode     String
  status          String
  attemptNumber   Int
  requestPayload  Json
  responsePayload Json?
  errorMessage    String?
  meta_data       Json?
  attemptedAt     DateTime @default(now())

  fulfillment Fulfillment? @relation(fields: [fulfillmentId], references: [id], onDelete: SetNull)
  city        City?        @relation("BookingAttemptCity", fields: [cityId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([fulfillmentId])
  @@index([courierCode, status])
  @@index([cityId])
}

// ADDRESS MATCH LOG (audit + ground truth for matcher improvements)
model AddressMatchLog {
  id String @id @default(cuid())

  shopId  String?
  orderId String?

  // Raw input the customer entered
  rawAddress1 String
  rawAddress2 String?
  rawCity     String?

    // Snapshots — fixed at write time, immune to later renames
  matchedAreaName   String?
  matchedAreaNorm   String?   // the specific norm (primary or alias) that hit
  chosenAreaName    String?
  normalizedAddress String?   // your normalize() output of rawAddress1 + rawAddress2

  // Matcher version for future A/B comparison
  matcherVersion    String?   @default("1.0")

  // What the matcher returned (may all be null if it bailed)
  matchedCityId   String?
  matchedAreaId   String?
  matchMethod     String? // 'substring' | 'token' | 'fuzzy' | 'zone-only' | null
  matchConfidence Float?
  matchedZone     String?

  // Ground truth from merchant (filled later when they correct or confirm)
  chosenCityId String?
  chosenAreaId String?
  chosenAt     DateTime?

  // Lifecycle state
  outcome String // 'unmatched' | 'auto_matched' | 'corrected' | 'confirmed' | 'manual_picked'

  // Has a curator reviewed this row to derive an alias? (cron will set true)
  aliasReviewed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop        Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  matchedCity City?   @relation("MatchedCity", fields: [matchedCityId], references: [id], onDelete: SetNull)
  matchedArea Area?   @relation("MatchedArea", fields: [matchedAreaId], references: [id], onDelete: SetNull)
  chosenCity  City?   @relation("ChosenCity", fields: [chosenCityId], references: [id], onDelete: SetNull)
  chosenArea  Area?   @relation("ChosenArea", fields: [chosenAreaId], references: [id], onDelete: SetNull)
  orders      Order[]

  @@index([shopId, outcome])
  @@index([chosenAreaId])
  @@index([matchedAreaId])
  @@index([createdAt])
  @@index([aliasReviewed, outcome])
}

// CUSTOM TAB (per-shop saved filters for the orders page)
model CustomTab {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  // Saved filter spec: { fulfillmentStatuses?: string[], tags?: string[],
  // financialStatuses?: string[], orderStatuses?: string[], dateRange?: { preset?: "today"|"yesterday"|"last7"|"custom", from?: string, to?: string } }
  filters       Json
  // Subset of bulk action button ids to show on this tab.
  actionButtons Json     @default("[]")
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, position])
}

// STOPPED ORDER (Free-plan orders received over webhook after credits exhausted)
//
// These rows hold the raw orders/create webhook payload so we can replay them
// into Order if the merchant upgrades. We only ever write — replay is a manual
// step done elsewhere.
model StoppedOrder {
  id              String   @id @default(cuid())
  shopId          String
  shopifyOrderId  BigInt
  // Light denormalised fields for the dashboard summary; the source of truth
  // for restoring is `payload`.
  orderName       String?
  customerName    String?
  totalAmount     Float?
  payload         Json
  receivedAt      DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, shopifyOrderId])
  @@index([shopId, receivedAt])
}
